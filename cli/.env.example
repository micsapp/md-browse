# Optional: agent token. Create one in your md-browse site under "Tokens"
# (visible to any logged-in user). The full secret is shown only once at creation.
# If unset, the CLI uses the active profile's saved token instead.
MD_BROWSE_TOKEN=agt_replace_me

# Optional: base URL of your md-browse site. Defaults to http://localhost.
# Accepts either form, with or without /api suffix — the suffix is normalized:
#   MD_BROWSE_URL=https://md.example.com
#   MD_BROWSE_URL=https://md.example.com/api
MD_BROWSE_URL=http://localhost

# Optional: pick a specific saved profile by name. Lower priority than
# --profile <name> on the command line.
# MD_BROWSE_PROFILE=md
